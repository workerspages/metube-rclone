{
    admin off
}

# 监听地址占位符，由 entrypoint.sh 在启动前替换
LISTEN_PLACEHOLDER {

    # /dav/* → rclone WebDAV
    handle /dav/* {
        uri strip_prefix /dav
        reverse_proxy 127.0.0.1:8082
    }

    # /* → metube Web UI（basicauth 用户名和哈希由 entrypoint.sh 写入）
    handle {
        basicauth {
            AUTH_PLACEHOLDER
        }
        reverse_proxy 127.0.0.1:8081
    }
}
